---
// DocLayout.astro
import "../assets/styles.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <!-- MathJax -->
    <script>
      window.MathJax = {
        tex: {
          inlineMath: [['$', '$'], ['\\(', '\\)']],
          displayMath: [['$$', '$$'], ['\\[', '\\]']]
        },
        svg: { fontCache: 'global' }
      };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>

    <title><slot name="title" /></title>
  </head>
  <body>
    <slot />
  </body>
</html>