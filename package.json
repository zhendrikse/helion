{
  "name": "helion",
  "version": "1.0.0",
  "type": "module",
  "description": "A web-based simulation environment for educational and scientific visualizations",
  "main": "./dist/helion.umd.js",
  "module": "./dist/helion.es.js",
  "exports": {
    ".": {
      "import": "./dist/helion.es.js",
      "require": "./dist/helion.umd.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "build:examples": "vite build --config vite.examples.config.js",
    "docs:build": "cd docs && npm install && npm run build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhendrikse/helion.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zhendrikse/helion/issues"
  },
  "homepage": "https://github.com/zhendrikse/helion#readme",
  "devDependencies": {
    "uplot": "^1.6.32",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "katex": "^0.17.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.184.0",
    "uplot": "^1.6.32"
  },
  "peerDependencies": {
    "three": "^0.184.0",
    "uplot": "^1.6.32"
  }
}
